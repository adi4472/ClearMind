{
  "expo": {
    "name": "ClearMind",
    "slug": "cognitive-hygiene-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "clearmind",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.clearmind"
    },
    "android": {
      "package": "com.example.clearmind"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#6FA58B"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4709f518-7763-46dd-a411-f625195e3905"
      }
    },
    "owner": "adi4472"
  }
}
